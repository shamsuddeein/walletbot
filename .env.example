# ==============================================================
# Copy this file to .env and fill in your values
# ==============================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgres://walletbot:walletbot@localhost:5432/walletbot

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Helius
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_WEBHOOK_ID=            # filled in after first webhook registration
HELIUS_WEBHOOK_SECRET=        # optional secret for payload verification

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here   # only this ID can run commands

# Webhook URL (your public ngrok/VPS URL, no trailing slash)
# e.g. https://abc123.ngrok.io
WEBHOOK_BASE_URL=https://your-domain-or-ngrok-url

# OpenRouter API Key (for AI match analysis, risk scoring, and text memory)
OPENROUTER_API_KEY=your_openrouter_api_key_here
